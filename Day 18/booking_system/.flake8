# .flake8
[flake8]
# Игнорируемые ошибки
ignore =
    E203,  # Whitespace before ':'
    E266,  # Too many leading '#' for block comment
    E501,  # Line too long (используем black)
    W503,  # Line break before binary operator
    F401,  # Import не используется
    F403,  # from module import *
    F405,  # Name may be undefined
    E741,  # Ambiguous variable name
    C901,  # Function too complex
    WPS,   # WPS rules (for now)
    D100,  # Missing docstring in public module
    D101,  # Missing docstring in public class
    D102,  # Missing docstring in public method
    D103,  # Missing docstring in public function
    D104,  # Missing docstring in public package
    D105,  # Missing docstring in magic method
    D107,  # Missing docstring in __init__

# Максимальная длина строки (black использует 88)
max-line-length = 88

# Исключаемые директории
exclude =
    .git,
    .tox,
    venv,
    __pycache__,
    build,
    dist,
    migrations,
    .venv,
    env,
    node_modules,
    *.egg-info

# Настройки импортов
import-order-style = google
application-import-names = src

# Дополнительные правила
max-complexity = 10
docstring-convention = google

# Настройки для black совместимости
extend-ignore = E203, W503
per-file-ignores =
    __init__.py:F401
    tests/*:D100,D101,D102,D103,D104
    src/*/__init__.py:F401