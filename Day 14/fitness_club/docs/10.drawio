        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\ntop to bottom direction\nskinparam linetype ortho\nskinparam defaultFontName Arial\n\nclass \&quot;Сервис фитнес-клуба\\n(FitnessClubService)\&quot; as Service {\n    +Регистрация клиента()\n    +Покупка абонемента()\n    +Заморозка абонемента()\n    +Создание тренировки()\n    +Запись на тренировку()\n    +Учёт посещения()\n    +Расчёт скидки()\n}\n\ninterface \&quot;Репозиторий клиентов\&quot; as ClientRepo\ninterface \&quot;Репозиторий абонементов\&quot; as MembershipRepo\ninterface \&quot;Репозиторий тренировок\&quot; as WorkoutRepo\ninterface \&quot;Репозиторий записей\&quot; as BookingRepo\n\nclass \&quot;Хранилище клиентов\\n(InMemoryClientRepository)\&quot; as InClientRepo\nclass \&quot;Хранилище абонементов\\n(InMemoryMembershipRepository)\&quot; as InMembershipRepo\nclass \&quot;Хранилище тренировок\\n(InMemoryWorkoutRepository)\&quot; as InWorkoutRepo\nclass \&quot;Хранилище записей\\n(InMemoryBookingRepository)\&quot; as InBookingRepo\n\nService --&gt; ClientRepo\nService --&gt; MembershipRepo\nService --&gt; WorkoutRepo\nService --&gt; BookingRepo\n\nInClientRepo ..|&gt; ClientRepo\nInMembershipRepo ..|&gt; MembershipRepo\nInWorkoutRepo ..|&gt; WorkoutRepo\nInBookingRepo ..|&gt; BookingRepo\n\nnote bottom\nРеализация Dependency Injection:\nсервисный слой работает через интерфейсы\nрепозиториев и не зависит от способа хранения данных.\nend note\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="W7V7cECW3yOvKm9DYj4Y-27">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
